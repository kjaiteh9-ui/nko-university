# ============================================================
# NKO UNIVERSITY — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# ── Supabase (Required) ──────────────────────────────────────
# Get from: https://supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── OpenAI (Required for AI features) ───────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-key-here

# ── Email / SMTP (Optional — for contact & support forms) ───
# Use Gmail SMTP, Mailgun, or any SMTP provider
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password

# Email destination for contact/support forms
CONTACT_EMAIL_TO=kjaiteh9@gmail.com
CONTACT_EMAIL_FROM=noreply@nkouniversity.com

# ── n8n Webhooks → Google Sheets (Optional) ─────────────────
# Create webhooks in your n8n instance that write to Google Sheets
# Contact form webhook
NEXT_PUBLIC_N8N_CONTACT_WEBHOOK=https://rossan.app.n8n.cloud/webhook/nko-contact
# Support form webhook
NEXT_PUBLIC_N8N_SUPPORT_WEBHOOK=https://rossan.app.n8n.cloud/webhook/nko-support

# ── App Config ───────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=NKO Online University
